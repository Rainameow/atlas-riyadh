# Copy to `.env` and adjust as needed. All variables are optional; the defaults
# in atlas_core.config.settings describe a standard local development setup.

# --- Application ---
ATLAS_ENVIRONMENT=development
ATLAS_DEBUG=true
ATLAS_LOG_LEVEL=INFO
ATLAS_LOG_JSON=false

# --- City (central Riyadh bounding box) ---
ATLAS_CITY_NAME=Riyadh
ATLAS_CITY_CENTER_LAT=24.7136
ATLAS_CITY_CENTER_LON=46.6753

# --- Database (PostGIS) ---
ATLAS_DB_HOST=localhost
ATLAS_DB_PORT=5432
ATLAS_DB_USER=atlas
ATLAS_DB_PASSWORD=atlas
ATLAS_DB_NAME=atlas

# --- Redis ---
ATLAS_REDIS_HOST=localhost
ATLAS_REDIS_PORT=6379

# --- Simulation ---
ATLAS_SIM_RANDOM_SEED=42
ATLAS_SIM_DEFAULT_POPULATION=1000
ATLAS_SIM_MINUTES_PER_TICK=5
